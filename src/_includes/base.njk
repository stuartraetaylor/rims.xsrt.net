<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}{% if title %} | {% endif %}Wheel offset and fitment comparison tools</title>

<script type="text/javascript" src="/scripts/jquery/jquery-3.7.1.min.js"></script>

<script type="text/javascript" src="/scripts/common.js"></script>
<script type="text/javascript" src="/scripts/garagelsd.offset.js"></script>

<link rel="stylesheet" type="text/css" media="all" href="/style/main.css" />
<link rel="stylesheet" type="text/css" media="all" href="/scripts/style.offset.css" />
</head>

<body class="bg-[var(--color-page-bg)] text-[var(--color-text)] font-sans text-sm leading-relaxed">

<!-- Navigation -->
<nav class="fixed top-0 w-full bg-[var(--color-nav-bg)] z-50">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-10">
    <span class="text-[var(--color-nav-link)] font-bold text-sm hidden md:block">RIMS</span>
    <!-- Hamburger (mobile) -->
    <button id="nav-toggle" class="md:hidden text-[var(--color-nav-link)] text-2xl leading-none p-1"
            aria-label="Menu" aria-expanded="false">&#9776;</button>
    <!-- Nav links -->
    <ul id="nav-menu" class="
      hidden md:flex md:gap-4 md:items-center
      absolute md:static top-10 left-0 w-full md:w-auto
      bg-[var(--color-nav-bg)] md:bg-transparent
      flex-col md:flex-row
      font-bold text-sm
    ">
      <li id="nav-offset">
        <a href="/tools/offset" class="block px-4 py-3 md:py-0 text-[var(--color-nav-link)] hover:underline {% if navActive == 'offset' %}underline{% endif %}">
          Split Rim Offset
        </a>
      </li>
      <li id="nav-fitment">
        <a href="/tools/fitment" class="block px-4 py-3 md:py-0 text-[var(--color-nav-link)] hover:underline {% if navActive == 'fitment' %}underline{% endif %}">
          Wheel Fitment
        </a>
      </li>
      <li id="nav-equivalents">
        <a href="/tools/equivalents" class="block px-4 py-3 md:py-0 text-[var(--color-nav-link)] hover:underline {% if navActive == 'equivalents' %}underline{% endif %}">
          Equivalent Arch Clearance
        </a>
      </li>
    </ul>
  </div>
</nav>

<!-- Main content -->
<main id="content" class="entry-content max-w-6xl mx-auto px-4 pt-14 md:pt-16">
  <h1 class="sr-only">{{ title }}</h1>
  {{ content | safe }}
</main>

<script>
// Hamburger menu toggle
document.getElementById('nav-toggle').addEventListener('click', function() {
  var menu = document.getElementById('nav-menu');
  menu.classList.toggle('hidden');
  if (menu.classList.contains('hidden')) {
    this.setAttribute('aria-expanded', 'false');
  } else {
    menu.classList.add('flex');
    this.setAttribute('aria-expanded', 'true');
  }
});

// Mobile tab switching
(function() {
  var tabs = document.querySelectorAll('.mobile-tab');
  var panels = document.querySelectorAll('.tab-panel');
  if (!tabs.length) return;

  var activeTab = 'tab-calculator';

  function switchTab(targetId) {
    activeTab = targetId;
    tabs.forEach(function(t) {
      var isActive = t.getAttribute('data-tab') === targetId;
      t.classList.toggle('border-[var(--color-nav-link)]', isActive);
      t.classList.toggle('text-[var(--color-text-dark)]', isActive);
      t.classList.toggle('border-transparent', !isActive);
      t.classList.toggle('text-gray-400', !isActive);
    });
    applyLayout();
  }

  function applyLayout() {
    var isMobile = window.innerWidth < 1024;
    panels.forEach(function(p) {
      if (isMobile) {
        p.classList.toggle('hidden', p.id !== activeTab);
        p.classList.toggle('block', p.id === activeTab);
      } else {
        p.classList.remove('hidden');
        p.classList.add('block');
      }
    });
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      switchTab(this.getAttribute('data-tab'));
    });
  });

  // Auto-switch to Results tab on form submit (mobile only)
  var form = document.querySelector('#offset-calculator form');
  if (form) {
    form.addEventListener('submit', function() {
      if (window.innerWidth < 1024) {
        setTimeout(function() { switchTab('tab-results'); }, 100);
      }
    });
  }

  window.addEventListener('resize', applyLayout);
})();
</script>

</body>
</html>
