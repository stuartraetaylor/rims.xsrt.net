<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}{% if title %} | {% endif %}Wheel offset and fitment comparison tools</title>

<script type="text/javascript" src="{{ '/scripts/jquery/jquery-3.7.1.min.js' | cacheBust }}"></script>

<script type="text/javascript" src="{{ '/scripts/common.js' | cacheBust }}"></script>
<script type="text/javascript" src="{{ '/scripts/garagelsd.offset.js' | cacheBust }}"></script>

<link rel="stylesheet" type="text/css" media="all" href="{{ '/style/main.css' | cacheBust }}" />
<link rel="stylesheet" type="text/css" media="all" href="{{ '/scripts/style.offset.css' | cacheBust }}" />
</head>

<body class="page-body">

<!-- Navigation -->
<nav class="site-nav">
  <div class="site-nav-inner">
    <span class="site-nav-brand">RIMS</span>
    <!-- Hamburger (mobile) -->
    <button id="nav-toggle" class="site-nav-toggle"
            aria-label="Menu" aria-expanded="false">&#9776; Calculators</button>
    <!-- Nav links -->
    <ul id="nav-menu" class="site-nav-menu">
      <li id="nav-offset">
        <a href="/tools/offset" class="site-nav-link {% if navActive == 'offset' %}underline{% endif %}">
          Split Rim Offset
        </a>
      </li>
      <li id="nav-fitment">
        <a href="/tools/fitment" class="site-nav-link {% if navActive == 'fitment' %}underline{% endif %}">
          Wheel Fitment
        </a>
      </li>
      <li id="nav-equivalents">
        <a href="/tools/equivalents" class="site-nav-link {% if navActive == 'equivalents' %}underline{% endif %}">
          Equivalent Arch Clearance
        </a>
      </li>
    </ul>
  </div>
</nav>

<!-- Menu overlay (closes hamburger menu on outside tap) -->
<div id="nav-overlay" class="nav-overlay hidden"></div>

<!-- Main content -->
<main id="content" class="entry-content page-content">
  <h1 class="sr-only">{{ title }}</h1>
  {{ content | safe }}
</main>

<script>
// Hamburger menu toggle
(function() {
  var toggle = document.getElementById('nav-toggle');
  var menu = document.getElementById('nav-menu');
  var overlay = document.getElementById('nav-overlay');

  function closeMenu() {
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    overlay.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
  }

  function openMenu() {
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    overlay.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
  }

  toggle.addEventListener('click', function() {
    if (menu.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  });

  overlay.addEventListener('click', closeMenu);
})();

// Mobile tab switching
(function() {
  var tabs = document.querySelectorAll('.mobile-tab');
  var panels = document.querySelectorAll('.tab-panel');
  if (!tabs.length) return;

  var activeTab = 'tab-calculator';
  var previousTab = null;

  function updateBackLinks() {
    document.querySelectorAll('.tab-back').forEach(function(link) {
      if (previousTab) {
        link.classList.remove('hidden');
      } else {
        link.classList.add('hidden');
      }
    });
  }

  window.switchTab = function(targetId) {
    if (targetId !== activeTab) {
      previousTab = activeTab;
    }
    activeTab = targetId;
    tabs.forEach(function(t) {
      var isActive = t.getAttribute('data-tab') === targetId;
      t.classList.toggle('tab-btn-active', isActive);
    });
    applyLayout();
    updateBackLinks();
  }

  window.goBack = function() {
    if (previousTab) {
      var target = previousTab;
      previousTab = null;
      switchTab(target);
    }
  }

  function applyLayout() {
    var isMobile = window.innerWidth < 1024;
    panels.forEach(function(p) {
      if (isMobile) {
        p.classList.toggle('hidden', p.id !== activeTab);
        p.classList.toggle('block', p.id === activeTab);
      } else {
        p.classList.remove('hidden');
        p.classList.add('block');
      }
    });
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      switchTab(this.getAttribute('data-tab'));
    });
  });

  // Auto-switch to Results tab on form submit (mobile only)
  var form = document.querySelector('#offset-calculator form');
  if (form) {
    form.addEventListener('submit', function() {
      if (window.innerWidth < 1024) {
        setTimeout(function() { switchTab('tab-results'); }, 100);
      }
    });
  }

  window.addEventListener('resize', applyLayout);
})();
</script>

</body>
</html>
