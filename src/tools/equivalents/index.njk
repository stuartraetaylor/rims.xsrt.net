<!-- Tab: Calculator -->
<div class="tab-panel" id="tab-calculator">
<div id="offset-calculator" class="calc-card">
<h3 class="calc-heading">Single Wheel Details</h3>
<form onsubmit="calculator.calculateEquivalents(this); return false;" onreset="calculator.clearall();">
<div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2">
  <div class="calc-field">
    <label for="wheelWidth" class="calc-label">Wheel width</label>
    <span class="calc-unit">(<abbr title="inches">in.</abbr>)</span>
    <input type="text" id="wheelWidth" name="wheelWidth" size="4" class="calc-input bg-[#FFE4B5]" />
  </div>
  <div class="calc-field">
    <label for="offset" class="calc-label">Wheel offset</label>
    <span class="calc-unit">(<abbr title="millimetres">mm</abbr>)</span>
    <input type="text" id="offset" name="offset" size="4" class="calc-input bg-[#FFE4B5]" />
  </div>
  <div class="calc-field">
    <label for="diameter" class="calc-label">Wheel diameter</label>
    <span class="calc-unit">(<abbr title="inches">in.</abbr>)</span>
    <input type="text" id="diameter" name="diameter" size="4" class="calc-input bg-[#F0F0F0]" />
  </div>
  <div class="calc-field">
    <label for="spacers" class="calc-label">Spacers</label>
    <span class="calc-unit">(<abbr title="millimetres">mm</abbr>)</span>
    <input type="text" id="spacers" name="spacers" size="4" value="0" class="calc-input bg-[#F0F0F0]" />
  </div>
</div>
<div class="calc-controls">
  <input type="submit" class="button" value="Calculate" />&nbsp;
  <input type="reset" class="button" value="Reset" />
</div>
</form>
</div>
